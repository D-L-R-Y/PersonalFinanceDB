{
  "name": "financedb",
  "productName": "FinanceDB",
  "version": "1.0.1",
  "description": "Personal finance tracker with a real SQLite database",
  "main": "main.js",
  "author": "FinanceDB",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.financedb.app",
    "productName": "FinanceDB",
    "icon": "icon.png",
    "files": [
      "index.html",
      "app.js",
      "style.css",
      "main.js",
      "icon.png",
      "vendor/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FinanceDB"
    },
    "directories": {
      "output": "dist"
    }
  }
}
